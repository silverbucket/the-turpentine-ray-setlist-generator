# Lightweight armadietto container for local real-backend e2e tests.
# Pinned to node:20-alpine for reproducibility; armadietto pulls the latest
# from npm at build time. Rebuild (docker compose build --no-cache) to bump.
FROM node:20-alpine
RUN npm install -g armadietto
COPY armadietto.conf.json /etc/armadietto/config.json
EXPOSE 8000
CMD ["armadietto", "-c", "/etc/armadietto/config.json"]
